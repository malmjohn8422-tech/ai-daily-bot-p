# AI API 代理地址（你的 cliproxyapi 地址）
AI_API_BASE=http://your-vps:8317/v1/chat/completions
AI_API_KEY=sk-xxx
AI_MODEL=gpt-4o

# Telegram Bot（从 @BotFather 创建）
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Email（Gmail 请使用应用专用密码）
EMAIL_USERNAME=your@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_RECIPIENT=you@domain.com

# GitHub Token（可选，用于 GitHub Trending 采集）
GITHUB_TOKEN=ghp_xxx

# Product Hunt Token（可选；未设置时会跳过 Product Hunt 来源）
PRODUCT_HUNT_TOKEN=your_product_hunt_token
